---
import Layout from '@/layouts/Layout.astro';
import RecallDetail from '@/components/recalls/RecallDetail';
import { getRecall, listRecalls, withConcurrency, withRetry } from '@/lib/api';
import type { RecallDetail as RecallDetailType } from '@/lib/api/recalls';

// Pre-render a bounded popular set (recent recalls) for SEO; the long tail is
// served by the client-fetch viewer (/recall-view) via the _redirects fallback.
export async function getStaticPaths() {
  const page = await withRetry(() => listRecalls({ limit: 8 }));
  const details = await withConcurrency(
    page.items.map((r) => () => withRetry(() => getRecall(r.source, r.source_recall_id))),
    4,
  );
  return details.map((detail) => ({
    params: { source: detail.source, recall_id: detail.source_recall_id },
    props: { detail },
  }));
}

interface Props {
  detail: RecallDetailType;
}
const { detail } = Astro.props as Props;
const title = detail.title ?? `${detail.source} recall ${detail.source_recall_id}`;
---

<Layout title={title} description={`${detail.source} recall ${detail.source_recall_id}.`}>
  <RecallDetail detail={detail} />
</Layout>
