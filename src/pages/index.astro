---
import Layout from '@/layouts/Layout.astro';
import Callout from '@/components/Callout.astro';
import AreaTrendChart from '@/components/charts/AreaTrendChart';
import SourceTotalsChart from '@/components/charts/SourceTotalsChart';
import ClassificationTable from '@/components/charts/ClassificationTable.astro';
import { getByClassification, getRecallsByPeriod, withRetry } from '@/lib/api';
import { classificationTableGroups, monthlyTrend, perSourceTotals } from '@/lib/charts/transforms';

// Build-time pull of the slow-moving aggregates (retried hard; fails the build loudly).
const [byPeriod, byClass] = await Promise.all([
  withRetry(() => getRecallsByPeriod({ grain: 'month' })),
  withRetry(() => getByClassification()),
]);

const trend = monthlyTrend(byPeriod, { source: 'ALL', sinceYear: 2012 });
const sourceTotals = perSourceTotals(byClass);
const classificationGroups = classificationTableGroups(byClass);
---

<Layout
  title="Consumer Product Recalls"
  description="Search and explore U.S. consumer product recalls across CPSC, FDA, USDA, NHTSA, and USCG — one unified, honest view."
>
  <section class="max-w-prose">
    <h1 class="text-4xl font-bold sm:text-5xl">Your online resource for recalls</h1>
    <p class="mt-4 text-lg text-muted">
      A unified, open access database of U.S. consumer product recalls from five federal agencies.
      Browse and filter every recall to check details like the firms involved, areas impacted, and
      products included. Data updates every day from publicly available sources.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/search"
        class="rounded-md bg-brand px-4 py-2 font-medium text-white no-underline hover:opacity-90"
        >Is my product recalled?</a
      >
      <a
        href="/recalls"
        class="rounded-md border border-line px-4 py-2 font-medium text-ink no-underline hover:bg-surface"
        >Browse all recalls</a
      >
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold">Over time</h2>
    <p class="mt-1 text-sm text-muted">From every source, by the month a recall was announced.</p>
    <AreaTrendChart
      client:visible
      data={trend}
      title="Recalls per month across all sources since 2012"
      caption="Monthly count of recall events, by each recall's announcement date, across all five sources. The latest month is partial."
    />
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold">By source</h2>
    <p class="mt-1 text-sm text-muted">Total recalls from each regulating agency.</p>
    <SourceTotalsChart
      client:visible
      data={sourceTotals}
      title="Total recalls by source"
      caption="Counts reflect each agency's reporting scope and history, not relative product risk."
    />
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold">By classification</h2>
    <p class="mt-1 text-sm text-muted">Separated by each agency's own recall severity level.</p>
    <div class="mt-4 max-w-2xl">
      <ClassificationTable groups={classificationGroups} />
    </div>
  </section>

  <section class="mt-12 max-w-prose">
    <Callout title="A note about this data">
      <p>
        These five regulators differ a little in their terminology, scope, and recall lifecycles.
        For most fields the data is kept source-native, and only combined where it clearly lines up.
        Counts reflect reporting practices, not product risk. Read the
        <a href="/methodology">methodology</a> before drawing conclusions.
      </p>
    </Callout>
  </section>
</Layout>
