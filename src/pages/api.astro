---
import Layout from '@/layouts/Layout.astro';
import ApiReference from '@/components/api/ApiReference';
---

<Layout
  title="API"
  description="The open, read-only API behind this site. No key, GET only, 60 requests a minute per IP."
>
  <section class="max-w-prose">
    <h1 class="text-3xl font-bold sm:text-4xl">Consumer Product Recalls API</h1>
    <p class="mt-2 text-muted">
      The whole site is built on a public, read-only API that is open for general use. No key
      required, GET requests only, open CORS, and keyset pagination, capped at 60 requests a minute
      per IP. The base URL is <code>https://api.consumer-product-recalls.info</code>.
    </p>
  </section>

  <div class="mt-6 rounded-lg border border-line">
    <ApiReference client:only="react" />
  </div>
</Layout>
